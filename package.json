{
  "name": "ascii-renderer",
  "version": "0.2.1",
  "description": "Pure-ASCII UI rendering engine: HTML/CSS input → ASCII art output on Canvas",
  "type": "module",
  "main": "dist/ascii-renderer.umd.cjs",
  "module": "dist/ascii-renderer.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/ascii-renderer.js",
      "require": "./dist/ascii-renderer.umd.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix"
  },
  "keywords": [
    "ascii",
    "renderer",
    "canvas",
    "html",
    "tui"
  ],
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.50.0",
    "eslint": "^10.0.2",
    "jsdom": "^28.1.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.56.1",
    "vite": "^6.1.0",
    "vite-plugin-dts": "^4.5.0",
    "vitest": "^3.0.0"
  }
}
